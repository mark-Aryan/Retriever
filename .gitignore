# =============================================
#   Retriever — Campus Lost & Found
#   .gitignore
# =============================================

# ── Python ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
*.whl
pip-wheel-metadata/
MANIFEST

# ── Virtual Environments ───────────────────
venv/
env/
.env/
.venv/
ENV/
env.bak/
venv.bak/

# ── Flask / App Specific ───────────────────
instance/
*.db
lostfound.db
flask_session/

# ── Uploads (user-generated content) ──────
static/uploads/*
!static/uploads/.gitkeep

# ── Environment Variables ──────────────────
.env
.env.local
.env.*.local
*.env

# ── IDE & Editor ──────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# ── Logs ──────────────────────────────────
*.log
logs/

# ── OS ────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Desktop.ini
ehthumbs.db
Thumbs.db

# ── Misc ──────────────────────────────────
*.bak
*.tmp
*.orig
